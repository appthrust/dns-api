{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "verbatimModuleSyntax": false,
    "paths": {
      "@appthrust/dns-api-ui": ["../../pkg/ts/ui/src/index.ts"]
    }
  },
  "include": ["./src/**/*", "../../pkg/ts/ui/src/**/*"]
}
